{% extends "layout.njk" %}

{% block content %}
<h1>📊 Reportes — El Tenedor</h1>

{% if error %}
  <div class="alert alert-error">⚠️ {{ error }}</div>
{% endif %}

<div class="card">
  <h2>🗓️ Filtros de Fecha</h2>
  <form method="GET" action="/reports">
    <div class="form-row" style="align-items:flex-end;">
      <div class="form-group">
        <label for="from">Desde</label>
        <input type="date" id="from" name="from" value="{{ from }}">
      </div>
      <div class="form-group">
        <label for="to">Hasta</label>
        <input type="date" id="to" name="to" value="{{ to }}">
      </div>
      <div class="form-group" style="flex:0;">
        <button type="submit" class="btn btn-primary">🔍 Consultar</button>
      </div>
    </div>
  </form>
</div>

{% if salesReport %}
<div class="card">
  <h2>💵 Reporte de Ventas</h2>
  <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:1rem; margin-bottom:1.25rem;">
    <div style="background:var(--dark-3); border:1px solid var(--border); border-radius:var(--radius-sm); padding:1rem; text-align:center;">
      <div style="font-size:1.6rem; font-weight:700; color:var(--purple-300);">{{ salesReport.totalSales or 0 }}</div>
      <div style="font-size:0.78rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; margin-top:0.25rem;">Total Ventas</div>
    </div>
    <div style="background:var(--dark-3); border:1px solid var(--border); border-radius:var(--radius-sm); padding:1rem; text-align:center;">
      <div style="font-size:1.6rem; font-weight:700; color:var(--success);">${{ salesReport.totalAmount or '0.00' }}</div>
      <div style="font-size:0.78rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; margin-top:0.25rem;">Monto Recaudado</div>
    </div>
  </div>
  <h2>Desglose por Método de Pago</h2>
  <table>
    <thead>
      <tr>
        <th>Método</th>
        <th>Monto</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>💵 Efectivo</td>
        <td style="color:var(--success); font-weight:600;">${{ (salesReport.byMethod.CASH if salesReport.byMethod and salesReport.byMethod.CASH) or '0.00' }}</td>
      </tr>
      <tr>
        <td>💳 Tarjeta de Crédito</td>
        <td style="color:var(--success); font-weight:600;">${{ (salesReport.byMethod.CREDIT_CARD if salesReport.byMethod and salesReport.byMethod.CREDIT_CARD) or '0.00' }}</td>
      </tr>
      <tr>
        <td>🏦 Tarjeta de Débito</td>
        <td style="color:var(--success); font-weight:600;">${{ (salesReport.byMethod.DEBIT_CARD if salesReport.byMethod and salesReport.byMethod.DEBIT_CARD) or '0.00' }}</td>
      </tr>
    </tbody>
  </table>
</div>
{% endif %}

{% if topProducts %}
<div class="card">
  <h2>🏆 Top 10 Productos Más Vendidos</h2>
  <table>
    <thead>
      <tr>
        <th style="width:48px;">#</th>
        <th>Producto</th>
        <th>Código</th>
        <th>Cantidad Vendida</th>
      </tr>
    </thead>
    <tbody>
      {% if topProducts.length > 0 %}
        {% for item in topProducts %}
          <tr>
            <td>
              {% if loop.index == 1 %}<span style="font-size:1.1rem;">🥇</span>
              {% elif loop.index == 2 %}<span style="font-size:1.1rem;">🥈</span>
              {% elif loop.index == 3 %}<span style="font-size:1.1rem;">🥉</span>
              {% else %}<span style="color:var(--text-muted);">{{ loop.index }}</span>
              {% endif %}
            </td>
            <td style="font-weight:500;">{{ item.productName or item.name }}</td>
            <td><code style="background:var(--dark-3);padding:0.15rem 0.4rem;border-radius:4px;font-size:0.82rem;color:var(--purple-300);">{{ item.productCode or item.code }}</code></td>
            <td style="font-weight:600; color:var(--purple-300);">{{ item.totalQuantity or item.quantity or 0 }} uds.</td>
          </tr>
        {% endfor %}
      {% else %}
        <tr><td colspan="4" class="empty-state">Sin datos para el período seleccionado.</td></tr>
      {% endif %}
    </tbody>
  </table>
</div>
{% endif %}

<div class="card" style="padding:0; overflow:hidden;">
  <div style="padding:1rem 1.5rem; border-bottom:1px solid var(--border);">
    <h2 style="margin:0;">🗃️ Reporte de Inventario</h2>
  </div>
  <table>
    <thead>
      <tr>
        <th>Código</th>
        <th>Nombre</th>
        <th>Precio</th>
        <th>Stock</th>
        <th>Estado</th>
      </tr>
    </thead>
    <tbody>
      {% if inventoryReport and inventoryReport.length > 0 %}
        {% for product in inventoryReport %}
          <tr class="{% if product.outOfStock %}out-of-stock{% elif product.lowStock %}low-stock{% endif %}">
            <td><code style="background:var(--dark-3);padding:0.15rem 0.4rem;border-radius:4px;font-size:0.82rem;color:var(--purple-300);">{{ product.code }}</code></td>
            <td style="font-weight:500;">{{ product.name }}</td>
            <td style="color:var(--purple-300); font-weight:600;">${{ product.price }}</td>
            <td><strong>{{ product.stockLevel }}</strong> <span style="color:var(--text-muted);font-size:0.8rem;">uds.</span></td>
            <td>
              {% if product.outOfStock %}
                <span class="badge badge-danger">⛔ Sin stock</span>
              {% elif product.lowStock %}
                <span class="badge badge-warning">⚠️ Stock bajo</span>
              {% else %}
                <span class="badge badge-ok">✓ OK</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      {% else %}
        <tr><td colspan="5" class="empty-state">Sin datos de inventario disponibles.</td></tr>
      {% endif %}
    </tbody>
  </table>
</div>
{% endblock %}
