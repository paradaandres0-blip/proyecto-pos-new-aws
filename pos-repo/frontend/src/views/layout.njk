<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Supermercado El Tenedor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ── Reset & Base ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple-900: #1a0533;
      --purple-800: #2d0a52;
      --purple-700: #3d1270;
      --purple-600: #5b21b6;
      --purple-500: #7c3aed;
      --purple-400: #a855f7;
      --purple-300: #c084fc;
      --purple-200: #e9d5ff;
      --purple-100: #f5f0ff;
      --black:      #0a0a0f;
      --dark-1:     #111118;
      --dark-2:     #1c1c27;
      --dark-3:     #252535;
      --dark-4:     #2e2e42;
      --gray-1:     #3d3d55;
      --gray-2:     #6b6b8a;
      --gray-3:     #9898b3;
      --white:      #ffffff;
      --off-white:  #f0eeff;
      --text-main:  #e8e4f5;
      --text-muted: #9898b3;
      --success:    #22c55e;
      --success-bg: #052e16;
      --danger:     #f43f5e;
      --danger-bg:  #2d0a14;
      --warning:    #f59e0b;
      --warning-bg: #2d1a00;
      --border:     rgba(124, 58, 237, 0.2);
      --shadow:     0 4px 24px rgba(0,0,0,0.4);
      --radius:     10px;
      --radius-sm:  6px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background: var(--black);
      color: var(--text-main);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* ── Scrollbar ────────────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--dark-1); }
    ::-webkit-scrollbar-thumb { background: var(--purple-600); border-radius: 3px; }

    /* ── Navbar ───────────────────────────────────────── */
    nav {
      background: var(--dark-1);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      height: 64px;
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(12px);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--white);
      margin-right: auto;
      letter-spacing: -0.3px;
    }

    .brand-icon {
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, var(--purple-500), var(--purple-400));
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      box-shadow: 0 0 12px rgba(124,58,237,0.5);
    }

    .brand span { color: var(--purple-300); }

    nav a {
      color: var(--gray-3);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.45rem 1rem;
      border-radius: var(--radius-sm);
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-left: 0.25rem;
    }

    nav a:hover {
      color: var(--white);
      background: var(--dark-3);
    }

    nav a.active, nav a:focus {
      color: var(--purple-300);
      background: rgba(124,58,237,0.15);
      border: 1px solid rgba(124,58,237,0.3);
    }

    /* ── Main Layout ──────────────────────────────────── */
    main {
      width: 100%;
      max-width: 100%;
      padding: 1.5rem 2.5rem 3rem;
    }

    /* ── Typography ───────────────────────────────────── */
    h1 {
      font-size: 2rem;
      font-weight: 800;
      color: var(--white);
      margin-bottom: 1.5rem;
      letter-spacing: -1px;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    h1::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, var(--border), transparent);
      margin-left: 0.75rem;
    }

    h2 {
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--purple-300);
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* ── Cards ────────────────────────────────────────── */
    .card {
      background: var(--dark-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      box-shadow: var(--shadow);
      transition: border-color 0.2s;
    }

    .card:hover { border-color: rgba(124,58,237,0.35); }

    /* ── Tables ───────────────────────────────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--dark-2);
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
    }

    thead { background: var(--dark-3); }

    th {
      padding: 0.85rem 1rem;
      text-align: left;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--purple-300);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      border-bottom: 1px solid var(--border);
    }

    td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      font-size: 0.9rem;
      color: var(--text-main);
    }

    tr:last-child td { border-bottom: none; }

    tbody tr { transition: background 0.15s; }
    tbody tr:hover { background: rgba(124,58,237,0.06); }

    tr.low-stock td { background: rgba(245,158,11,0.08); }
    tr.low-stock:hover td { background: rgba(245,158,11,0.13); }
    tr.out-of-stock td { background: rgba(244,63,94,0.08); }
    tr.out-of-stock:hover td { background: rgba(244,63,94,0.13); }

    /* ── Buttons ──────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1.1rem;
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: inherit;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .btn:active { transform: scale(0.97); }

    .btn-primary {
      background: linear-gradient(135deg, var(--purple-600), var(--purple-500));
      color: var(--white);
      box-shadow: 0 2px 12px rgba(124,58,237,0.35);
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, var(--purple-500), var(--purple-400));
      box-shadow: 0 4px 18px rgba(124,58,237,0.5);
    }

    .btn-success {
      background: linear-gradient(135deg, #16a34a, var(--success));
      color: var(--white);
      box-shadow: 0 2px 10px rgba(34,197,94,0.25);
    }
    .btn-success:hover { box-shadow: 0 4px 16px rgba(34,197,94,0.4); filter: brightness(1.1); }

    .btn-danger {
      background: rgba(244,63,94,0.15);
      color: var(--danger);
      border: 1px solid rgba(244,63,94,0.3);
    }
    .btn-danger:hover { background: rgba(244,63,94,0.25); border-color: var(--danger); }

    .btn-secondary {
      background: var(--dark-4);
      color: var(--gray-3);
      border: 1px solid var(--gray-1);
    }
    .btn-secondary:hover { background: var(--gray-1); color: var(--white); }

    /* ── Forms ────────────────────────────────────────── */
    .form-group { margin-bottom: 1rem; }

    .form-group label {
      display: block;
      margin-bottom: 0.4rem;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--gray-3);
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }

    .form-group input,
    .form-group select {
      width: 100%;
      padding: 0.6rem 0.85rem;
      background: var(--dark-3);
      border: 1px solid var(--gray-1);
      border-radius: var(--radius-sm);
      font-size: 0.9rem;
      font-family: inherit;
      color: var(--white);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    .form-group input::placeholder { color: var(--gray-2); }

    .form-group input:focus,
    .form-group select:focus {
      border-color: var(--purple-500);
      box-shadow: 0 0 0 3px rgba(124,58,237,0.2);
    }

    .form-group select option { background: var(--dark-3); }

    .form-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .form-row .form-group { flex: 1; min-width: 150px; }

    /* ── Alerts ───────────────────────────────────────── */
    .alert {
      padding: 0.8rem 1rem;
      border-radius: var(--radius-sm);
      margin-bottom: 1rem;
      font-size: 0.875rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .alert-error {
      background: var(--danger-bg);
      color: #fca5a5;
      border: 1px solid rgba(244,63,94,0.3);
    }

    .alert-success {
      background: var(--success-bg);
      color: #86efac;
      border: 1px solid rgba(34,197,94,0.3);
    }

    /* ── Total / Change boxes ─────────────────────────── */
    .total-box {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--white);
      padding: 0.75rem 0;
      letter-spacing: -0.5px;
    }

    .total-box span { color: var(--purple-300); }

    .change-box {
      font-size: 1.2rem;
      color: var(--success);
      font-weight: 600;
      padding: 0.5rem 0.75rem;
      background: var(--success-bg);
      border: 1px solid rgba(34,197,94,0.25);
      border-radius: var(--radius-sm);
      display: inline-block;
    }

    /* ── Modal ────────────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(4px);
      z-index: 100;
      justify-content: center;
      align-items: center;
    }

    .modal-overlay.open { display: flex; }

    .modal {
      background: var(--dark-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
      animation: slideUp 0.2s ease;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .modal h2 { margin-bottom: 1.25rem; color: var(--white); font-size: 1.1rem; }

    .modal-actions {
      display: flex;
      gap: 0.75rem;
      justify-content: flex-end;
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    /* ── Badges ───────────────────────────────────────── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.3px;
    }

    .badge-warning {
      background: var(--warning-bg);
      color: var(--warning);
      border: 1px solid rgba(245,158,11,0.3);
    }

    .badge-danger {
      background: var(--danger-bg);
      color: var(--danger);
      border: 1px solid rgba(244,63,94,0.3);
    }

    .badge-ok {
      background: var(--success-bg);
      color: var(--success);
      border: 1px solid rgba(34,197,94,0.3);
    }

    /* ── Divider ──────────────────────────────────────── */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 1.25rem 0;
    }

    /* ── Empty state ──────────────────────────────────── */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    /* ── Stat chip ────────────────────────────────────── */
    .stat-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(124,58,237,0.1);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 0.3rem 0.8rem;
      font-size: 0.8rem;
      color: var(--purple-300);
      font-weight: 500;
    }
  </style>
</head>
<body>
  <nav>
    <div class="brand">
      <div class="brand-icon">🍴</div>
      Supermercado <span>El Tenedor</span>
    </div>
    <a href="/sale">🧾 Ventas</a>
    <a href="/inventory">📦 Inventario</a>
    <a href="/reports">📊 Reportes</a>
  </nav>
  <main>
    {% block content %}{% endblock %}
  </main>
</body>
</html>
